<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Typography Styles -->
    <Style x:Key="HeadingLarge" TargetType="Label">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.2" />
    </Style>

    <Style x:Key="HeadingMedium" TargetType="Label">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.3" />
    </Style>

    <Style x:Key="HeadingSmall" TargetType="Label">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.4" />
    </Style>

    <Style x:Key="SubheadingLarge" TargetType="Label">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="SubheadingMedium" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
    </Style>

    <Style x:Key="BodyLarge" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.5" />
    </Style>

    <Style x:Key="BodyMedium" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="LineHeight" Value="1.5" />
    </Style>

    <Style x:Key="BodySmall" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextSecondary}" />
        <Setter Property="LineHeight" Value="1.4" />
    </Style>

    <Style x:Key="Caption" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource TextTertiary}" />
    </Style>

    <!-- Button Styles -->
    <Style x:Key="ButtonPrimary" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnPrimary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource Shadow}" Offset="0,2" Radius="8" Opacity="0.1" />
            </Setter.Value>
        </Setter>
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="Pressed">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryDark}" />
                            <Setter Property="Scale" Value="0.96" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Gray300}" />
                            <Setter Property="TextColor" Value="{StaticResource Gray500}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style x:Key="ButtonSecondary" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource Secondary}" />
        <Setter Property="TextColor" Value="{StaticResource TextOnSecondary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource Shadow}" Offset="0,2" Radius="8" Opacity="0.1" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ButtonOutline" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="20,0" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="2" />
    </Style>

    <Style x:Key="ButtonGhost" TargetType="Button">
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="HeightRequest" Value="48" />
        <Setter Property="Padding" Value="20,0" />
    </Style>

    <!-- Entry Styles -->
    <Style x:Key="EntryDefault" TargetType="Entry">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
        <Setter Property="HeightRequest" Value="56" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Focused">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <!-- Editor Styles -->
    <Style x:Key="EditorDefault" TargetType="Editor">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
    </Style>

    <!-- Picker Styles -->
    <Style x:Key="PickerDefault" TargetType="Picker">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
    </Style>

    <!-- Frame Styles -->
    <Style x:Key="CardStyle" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource Shadow}" Offset="0,4" Radius="12" Opacity="0.1" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardElevated" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
        <Setter Property="BorderColor" Value="Transparent" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="HasShadow" Value="False" />
        <Setter Property="Shadow">
            <Setter.Value>
                <Shadow Brush="{StaticResource ShadowDark}" Offset="0,8" Radius="24" Opacity="0.15" />
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardOutline" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderPrimary}" />
        <Setter Property="CornerRadius" Value="16" />
        <Setter Property="Padding" Value="20" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- Status Badge Styles -->
    <Style x:Key="BadgeSuccess" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Success}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="BadgeWarning" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Warning}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="BadgeError" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Error}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <Style x:Key="BadgeInfo" TargetType="Frame">
        <Setter Property="BackgroundColor" Value="{StaticResource Info}" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="HasShadow" Value="False" />
    </Style>

    <!-- Page Styles -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimary}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="{StaticResource BackgroundPrimary}" />
        <Setter Property="ForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TitleColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="DisabledColor" Value="{StaticResource Gray400}" />
        <Setter Property="UnselectedColor" Value="{StaticResource Gray500}" />
        <Setter Property="TabBarBackgroundColor" Value="{StaticResource SurfacePrimary}" />
        <Setter Property="TabBarForegroundColor" Value="{StaticResource Primary}" />
        <Setter Property="TabBarUnselectedColor" Value="{StaticResource Gray500}" />
        <Setter Property="TabBarTitleColor" Value="{StaticResource Primary}" />
    </Style>

    <Style x:Key="SearchBarDefault" TargetType="SearchBar">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfacePrimary}" />
        <Setter Property="TextColor" Value="{StaticResource TextPrimary}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource TextTertiary}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="52" />
        <Setter Property="CancelButtonColor" Value="{StaticResource Primary}" />
    </Style>
    
</ResourceDictionary>