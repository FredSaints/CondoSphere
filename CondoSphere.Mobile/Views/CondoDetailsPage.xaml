<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CondoSphere.Mobile.ViewModels"
             xmlns:dto="clr-namespace:CondoSphere.Core.DTOs.Occurrences;assembly=CondoSphere.Core"
             x:DataType="vm:CondoDetailsViewModel"
             x:Class="CondoSphere.Mobile.Views.CondoDetailsPage"
             Title="{Binding Condo.Name}">

    <Grid RowDefinitions="*">
        <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" ZIndex="1"/>
        <CollectionView x:Name="occurrencesCollectionView"
                         ItemsSource="{Binding OpenOccurrences}"
                         SelectionMode="Single">
            <CollectionView.Header>
                <VerticalStackLayout Padding="15">
                    <Label Text="{Binding Condo.Address}" TextColor="Gray"/>
                    <Label Text="Open Occurrences" FontSize="20" FontAttributes="Bold" Margin="0,10,0,0"/>
                </VerticalStackLayout>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="dto:OccurrenceDto">
                    <Frame Padding="10" Margin="15,0,15,10" CornerRadius="5" BorderColor="LightGray">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={RelativeSource AncestorType={x:Type vm:CondoDetailsViewModel}}, Path=GoToOccurrenceDetailsCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Spacing="5">
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label Text="{Binding ReportedByUserName, StringFormat='Reported by: {0}'}" FontSize="Small" />
                            </VerticalStackLayout>
                            <Label Grid.Column="1" Text="{Binding Status}" VerticalOptions="Center" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <Label Text="No open occurrences for this condominium." Padding="20" HorizontalTextAlignment="Center" VerticalTextAlignment="Center"/>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>

</ContentPage>