<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CondoSphere.Mobile.ViewModels"
             x:DataType="vm:AdminDashboardViewModel"
             x:Class="CondoSphere.Mobile.Views.AdminDashboardPage"
             BackgroundColor="{StaticResource BackgroundSecondary}"
             Title="Dashboard">

    <Grid RowDefinitions="Auto,*">

        <!-- Loading Overlay -->
        <Frame Grid.RowSpan="2" 
               BackgroundColor="#80000000"
               IsVisible="{Binding IsBusy}"
               ZIndex="999"
               Padding="0">
            <ActivityIndicator IsRunning="{Binding IsBusy}" 
                             Color="{StaticResource Primary}"
                             HeightRequest="48"
                             WidthRequest="48"
                             VerticalOptions="Center" 
                             HorizontalOptions="Center" />
        </Frame>

        <!-- Header -->
        <Frame Grid.Row="0"
               BackgroundColor="{StaticResource Primary}"
               CornerRadius="24"
               HasShadow="False"
               Padding="24,40,24,24"
               Margin="0,0,0,20">
            <Frame.Shadow>
                <Shadow Brush="{StaticResource ShadowDark}" 
                        Offset="0,4" 
                        Radius="12" 
                        Opacity="0.15" />
            </Frame.Shadow>

            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="4">
                    <Label Text="Company Overview" 
                           Style="{StaticResource HeadingMedium}"
                           TextColor="{StaticResource TextOnPrimary}" />
                    <Label Text="Real-time insights into your properties"
                           Style="{StaticResource BodyMedium}"
                           TextColor="{StaticResource TextOnPrimary}"
                           Opacity="0.9" />
                </VerticalStackLayout>

                <!-- Settings Icon -->
                <Frame Grid.Column="1"
                       BackgroundColor="{StaticResource TextOnPrimary}"
                       CornerRadius="20"
                       HeightRequest="40"
                       WidthRequest="40"
                       Padding="0"
                       HasShadow="False">
                    <Label Text="⚙️" 
                           FontSize="18"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Frame>
            </Grid>
        </Frame>

        <!-- Main Content -->
        <RefreshView Grid.Row="1" 
                     Command="{Binding LoadDataCommand}" 
                     IsRefreshing="{Binding IsBusy}">
            <ScrollView>
                <VerticalStackLayout Spacing="24" Padding="20,0,20,40">

                    <!-- KPI Cards Grid -->
                    <Grid ColumnDefinitions="*,*" 
                          RowDefinitions="Auto,Auto,Auto" 
                          RowSpacing="16" 
                          ColumnSpacing="16">

                        <!-- Properties Card -->
                        <Frame Grid.Row="0" Grid.Column="0" 
                               Style="{StaticResource CardElevated}"
                               Padding="20">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="🏢" FontSize="32" HorizontalOptions="Center" />
                                <Label Text="{Binding Stats.TotalCondominiums}" 
                                       Style="{StaticResource HeadingLarge}"
                                       TextColor="{StaticResource Primary}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Properties" 
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Units Card -->
                        <Frame Grid.Row="0" Grid.Column="1" 
                               Style="{StaticResource CardElevated}"
                               Padding="20">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="🏠" FontSize="32" HorizontalOptions="Center" />
                                <Label Text="{Binding Stats.TotalUnits}" 
                                       Style="{StaticResource HeadingLarge}"
                                       TextColor="{StaticResource Secondary}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Total Units" 
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Residents Card -->
                        <Frame Grid.Row="1" Grid.Column="0" 
                               Style="{StaticResource CardElevated}"
                               Padding="20">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="👥" FontSize="32" HorizontalOptions="Center" />
                                <Label Text="{Binding Stats.TotalResidents}" 
                                       Style="{StaticResource HeadingLarge}"
                                       TextColor="{StaticResource Info}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Residents" 
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Open Issues Card -->
                        <Frame Grid.Row="1" Grid.Column="1" 
                               Style="{StaticResource CardElevated}"
                               Padding="20">
                            <VerticalStackLayout Spacing="12">
                                <Label Text="⚠️" FontSize="32" HorizontalOptions="Center" />
                                <Label Text="{Binding Stats.OpenOccurrences}" 
                                       Style="{StaticResource HeadingLarge}"
                                       TextColor="{StaticResource Warning}"
                                       HorizontalTextAlignment="Center" />
                                <Label Text="Open Issues" 
                                       Style="{StaticResource BodyMedium}"
                                       HorizontalTextAlignment="Center" />
                            </VerticalStackLayout>
                        </Frame>

                        <!-- Income/Expenses Cards (Full Width) -->
                        <Frame Grid.Row="2" Grid.ColumnSpan="2" 
                               Style="{StaticResource CardElevated}"
                               Padding="20">
                            <Grid ColumnDefinitions="*,*" ColumnSpacing="20">

                                <!-- Income Side -->
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="💰 Monthly Income" 
                                           Style="{StaticResource SubheadingMedium}"
                                           TextColor="{StaticResource Success}" />
                                    <Label Text="{Binding Stats.TotalIncomeThisMonth, StringFormat='€{0:N0}'}" 
                                           Style="{StaticResource HeadingMedium}"
                                           TextColor="{StaticResource Success}" />
                                </VerticalStackLayout>

                                <!-- Expenses Side -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Label Text="💸 Monthly Expenses" 
                                           Style="{StaticResource SubheadingMedium}"
                                           TextColor="{StaticResource Error}" />
                                    <Label Text="{Binding Stats.TotalExpensesThisMonth, StringFormat='€{0:N0}'}" 
                                           Style="{StaticResource HeadingMedium}"
                                           TextColor="{StaticResource Error}" />
                                </VerticalStackLayout>
                            </Grid>
                        </Frame>
                    </Grid>

                    <!-- Quick Actions Section -->
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Quick Actions" 
                               Style="{StaticResource SubheadingLarge}" />

                        <Grid ColumnDefinitions="*,*" 
                              RowDefinitions="Auto,Auto" 
                              RowSpacing="12" 
                              ColumnSpacing="12">

                            <!-- Add Property -->
                            <Frame Grid.Row="0" Grid.Column="0" 
                                   Style="{StaticResource CardStyle}"
                                   Padding="16">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="🏢" FontSize="24" HorizontalOptions="Center" />
                                    <Label Text="Add Property" 
                                           Style="{StaticResource BodyMedium}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Manage Users -->
                            <Frame Grid.Row="0" Grid.Column="1" 
                                   Style="{StaticResource CardStyle}"
                                   Padding="16">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="👤" FontSize="24" HorizontalOptions="Center" />
                                    <Label Text="Manage Users" 
                                           Style="{StaticResource BodyMedium}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>

                            <!-- View Reports -->
                            <Frame Grid.Row="1" Grid.Column="0" 
                                   Style="{StaticResource CardStyle}"
                                   Padding="16">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="📊" FontSize="24" HorizontalOptions="Center" />
                                    <Label Text="View Reports" 
                                           Style="{StaticResource BodyMedium}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>

                            <!-- Settings -->
                            <Frame Grid.Row="1" Grid.Column="1" 
                                   Style="{StaticResource CardStyle}"
                                   Padding="16">
                                <Frame.GestureRecognizers>
                                    <TapGestureRecognizer />
                                </Frame.GestureRecognizers>
                                <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                                    <Label Text="⚙️" FontSize="24" HorizontalOptions="Center" />
                                    <Label Text="Settings" 
                                           Style="{StaticResource BodyMedium}"
                                           HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </Frame>
                        </Grid>
                    </VerticalStackLayout>

                    <!-- Recent Activity Section -->
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Recent Activity" 
                               Style="{StaticResource SubheadingLarge}" />

                        <Frame Style="{StaticResource CardStyle}">
                            <VerticalStackLayout Spacing="16">

                                <!-- Activity Item 1 -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                    <Frame CornerRadius="20"
                                           HeightRequest="40"
                                           WidthRequest="40"
                                           Padding="0"
                                           HasShadow="False"
                                           BackgroundColor="{StaticResource Success}">
                                        <Label Text="💰" 
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="Payment received from Unit 12A" 
                                               Style="{StaticResource BodyMedium}"
                                               FontAttributes="Bold" />
                                        <Label Text="Monthly maintenance fee - €450" 
                                               Style="{StaticResource BodySmall}" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2" 
                                           Text="2h ago" 
                                           Style="{StaticResource BodySmall}"
                                           VerticalOptions="Center" />
                                </Grid>

                                <!-- Separator -->
                                <BoxView HeightRequest="1" 
                                         BackgroundColor="{StaticResource BorderPrimary}" />

                                <!-- Activity Item 2 -->
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                    <Frame CornerRadius="20"
                                           HeightRequest="40"
                                           WidthRequest="40"
                                           Padding="0"
                                           HasShadow="False"
                                           BackgroundColor="{StaticResource Warning}">
                                        <Label Text="🔧" 
                                               FontSize="18"
                                               HorizontalOptions="Center"
                                               VerticalOptions="Center" />
                                    </Frame>

                                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                                        <Label Text="New maintenance request" 
                                               Style="{StaticResource BodyMedium}"
                                               FontAttributes="Bold" />
                                        <Label Text="Elevator issue reported by resident" 
                                               Style="{StaticResource BodySmall}" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="2" 
                                           Text="4h ago" 
                                           Style="{StaticResource BodySmall}"
                                           VerticalOptions="Center" />
                                </Grid>

                                <!-- View All Button -->
                                <Button Text="View All Activity" 
                                        Style="{StaticResource ButtonOutline}"
                                        HeightRequest="40"
                                        FontSize="14"
                                        Margin="0,8,0,0" />
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </RefreshView>
    </Grid>

</ContentPage>