<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CondoSphere.Mobile.ViewModels"
             xmlns:dto="clr-namespace:CondoSphere.Core.DTOs.Condominiums;assembly=CondoSphere.Core"
             x:DataType="vm:DocumentsViewModel"
             x:Class="CondoSphere.Mobile.Views.DocumentsPage"
             Title="Documents">

    <Grid RowDefinitions="*">
        <ActivityIndicator IsRunning="{Binding IsBusy}" VerticalOptions="Center" HorizontalOptions="Center" />
        <RefreshView Command="{Binding LoadDataCommand}" IsRefreshing="{Binding IsBusy}">

            <CollectionView x:Name="documentsCollectionView" 
                            ItemsSource="{Binding Documents}" 
                            SelectionMode="Single">

                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="dto:DocumentDto">
                        <Frame Padding="15" Margin="10,5" CornerRadius="5" BorderColor="LightGray">
                            <VerticalStackLayout>
                                <Label Text="{Binding Title}" FontAttributes="Bold" />
                                <Label Text="{Binding Category, StringFormat='Category: {0}'}" FontSize="Small" TextColor="Gray" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>

  