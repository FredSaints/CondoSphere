<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:CondoSphere.Mobile"
             xmlns:converters="clr-namespace:CondoSphere.Mobile.Converters"
             x:Class="CondoSphere.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Add Value Converters -->
            <converters:StatusToColorConverter x:Key="StatusToColorConverter" />
            <converters:IsNotNullConverter x:Key="IsNotNullConverter" />
            <converters:HasItemsConverter x:Key="HasItemsConverter" />
            <converters:StatusToBoolConverter x:Key="StatusToBoolConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
