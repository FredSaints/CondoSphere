@model IEnumerable<CondoSphere.Core.DTOs.Financials.ExpenseDto>
@using CondoSphere.Core.DTOs.Condominiums

@{
    var condo = ViewData["Condominium"] as CondominiumDto;
    ViewData["Title"] = $"Fixed Expenses for {condo?.Name ?? "Condominium"}";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1>@ViewData["Title"]</h1>
        <p class="text-muted">Manage recurring monthly, quarterly, or annual expenses for this condominium.</p>
    </div>
    <a asp-action="CreateFixedExpense" asp-route-condominiumId="@condo.Id" class="btn btn-primary">
        <i class="bi bi-plus-circle-fill me-1"></i> Create New Fixed Expense
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Title</th>
                            <th class="text-end">Amount</th>
                            <th class="text-center">Frequency</th>
                            <th class="text-center">Day of Billing</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var expense in Model)
                        {
                            <tr>
                                <td>
                                    <strong>@expense.Title</strong>
                                    @if (!string.IsNullOrWhiteSpace(expense.Description))
                                    {
                                        <br />
                            
                                        <small class="text-muted">@expense.Description</small>
                                    }
                                </td>
                                <td class="text-end">@expense.Amount.ToString("C")</td>
                                <td class="text-center">@expense.Frequency</td>
                                <td class="text-center">@expense.DayOfBilling</td>
                                <td class="text-center">
                                    @if (expense.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                                <td class="text-end">
                                    <div class="btn-group" role="group" aria-label="Expense Actions">

                                        <a asp-action="EditFixedExpense"
                                           asp-route-condominiumId="@condo.Id"
                                           asp-route-expenseId="@expense.Id"
                                           class="btn btn-sm btn-outline-secondary" title="Edit">
                                            <i class="bi bi-pencil-fill"></i>
                                        </a>

                                        <form asp-action="ToggleFixedExpenseStatus"
                                              asp-route-condominiumId="@condo.Id"
                                              asp-route-expenseId="@expense.Id"
                                              method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm @(expense.IsActive ? "btn-outline-warning" : "btn-outline-success")" title="@(expense.IsActive ? "Deactivate" : "Activate")">
                                                <i class="bi @(expense.IsActive ? "bi-pause-circle" : "bi-play-circle")"></i>
                                            </button>
                                        </form>

                                        <form asp-action="DeleteFixedExpense"
                                              asp-route-condominiumId="@condo.Id"
                                              asp-route-expenseId="@expense.Id"
                                              method="post" class="d-inline"
                                              onsubmit="return confirm('Are you sure you want to permanently delete the expense: \'@expense.Title\'? This cannot be undone.');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash-fill"></i>
                                            </button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center p-5">
                <i class="bi bi-journal-x fs-1 text-muted"></i>
                <h4 class="mt-3">No Fixed Expenses Found</h4>
                <p class="text-muted">Click the "Create New Fixed Expense" button to add a recurring expense.</p>
            </div>
        }
    </div>
</div>

<div class="mt-4">
    <a asp-action="Details" asp-route-id="@condo.Id" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Condominium Details
    </a>
</div>