@model IEnumerable<CondoSphere.Core.DTOs.Condominiums.CondominiumDto>

@{
    ViewData["Title"] = "My Managed Condominiums";
}


<style>
    .condo-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        border: 2.5px solid #d1d5db;
        border-radius: 0.75rem;
    }

        .condo-card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-lg) !important;
        }

        .condo-card .card-body {
            display: flex;
            flex-direction: column;
            padding: 2rem;
        }

        .condo-card .card-title {
            font-weight: 600;
            color: var(--text-primary);
            font-size: 2rem;
        }

        .condo-card .btn {
            font-size: 1.1rem;
            padding-top: 0.75rem;
            padding-bottom: 0.75rem;
        }
</style>



<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">Select a property to manage its units, residents, and finances.</p>
    </div>
</div>

@if (Model.Any())
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var condo in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm condo-card">
                    <div class="card-body">
                        <div class="mb-3">
                            <h5 class="card-title">@condo.Name</h5>
                            <p class="card-text text-muted small">
                                <i class="bi bi-geo-alt-fill me-1"></i>
                                @condo.Address
                            </p>
                        </div>
                        <div class="mt-auto">
                            <a asp-controller="CondoManagement" asp-action="Details" asp-route-id="@condo.Id" class="btn btn-primary w-100">
                                <i class="bi bi-gear-fill me-1"></i> Manage Property
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center p-5 border rounded bg-light">
        <i class="bi bi-building-slash" style="font-size: 3rem; color: var(--text-secondary);"></i>
        <h4 class="mt-3">No Condominiums Assigned</h4>
        <p class="text-muted">You have not been assigned to manage any properties yet. Please contact your company administrator.</p>
    </div>
}