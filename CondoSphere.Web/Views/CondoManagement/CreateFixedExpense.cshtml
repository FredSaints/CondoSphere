@model CondoSphere.Core.DTOs.Financials.CreateUpdateFixedExpenseDto
@using CondoSphere.Core.Enums

@{
    ViewData["Title"] = "Create Fixed Expense";
}

<h1>@ViewData["Title"]</h1>
<p class="text-muted">For Condominium: <strong>@ViewData["CondominiumName"]</strong></p>
<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="CreateFixedExpense" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="CondominiumId" />

            <div class="form-floating mb-3">
                <input asp-for="Title" class="form-control" placeholder="e.g., Monthly Cleaning Service" />
                <label asp-for="Title"></label>
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <textarea asp-for="Description" class="form-control" placeholder="Optional notes..." style="height: 100px;"></textarea>
                <label asp-for="Description"></label>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="row">
                <div class="col-md-6 form-floating mb-3">
                    <input asp-for="Amount" class="form-control" type="number" step="0.01" inputmode="decimal" />
                    <label asp-for="Amount"></label>
                    <span asp-validation-for="Amount" class="text-danger"></span>
                </div>
                <div class="col-md-6 form-floating mb-3">
                    <select asp-for="Frequency" asp-items="Html.GetEnumSelectList<ExpenseFrequency>().Skip(1)" class="form-select">
                        <option value="">-- Select Frequency --</option>
                    </select>
                    <label asp-for="Frequency"></label>
                    <span asp-validation-for="Frequency" class="text-danger"></span>
                </div>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="DayOfBilling" class="form-control" type="number" />
                <label asp-for="DayOfBilling"></label>
                <div class="form-text">Enter a day from 1 to 28.</div>
                <span asp-validation-for="DayOfBilling" class="text-danger"></span>
            </div>


            <button type="submit" class="btn btn-success">Save Expense</button>
            <a asp-action="FixedExpenses" asp-route-condominiumId="@Model.CondominiumId" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}