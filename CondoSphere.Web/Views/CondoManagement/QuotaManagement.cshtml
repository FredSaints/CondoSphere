@model IEnumerable<CondoSphere.Core.DTOs.Financials.UnitQuotaDto>
@using CondoSphere.Core.DTOs.Condominiums
@using CondoSphere.Core.Enums

@{
    var condo = ViewData["Condominium"] as CondominiumDto;
    ViewData["Title"] = "Quota Management";
}

<h1>@ViewData["Title"]</h1>
<p class="text-muted">Review and confirm payments for <strong>@condo.Name</strong></p>
<hr />

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Description</th>
                            <th>Unit</th>
                            <th>Due Date</th>
                            <th class="text-end">Amount</th>
                            <th class="text-center">Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var quota in Model.OrderBy(q => q.Status == UnitQuotaStatus.PendingConfirmation ? 0 : 1))
                        {
                            <tr class="@(quota.Status == UnitQuotaStatus.PendingConfirmation ? "table-info" : "")">
                                <td>@quota.Description</td>
                                <td><strong>@quota.UnitIdentifier</strong></td>
                                <td>@quota.DueDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end">@quota.AmountDue.ToString("C")</td>
                                <td class="text-center">
                                    @{
                                        var statusClass = "bg-secondary";
                                        switch (quota.Status)
                                        {
                                            case UnitQuotaStatus.Pending: statusClass = "bg-warning text-dark"; break;
                                            case UnitQuotaStatus.Paid: statusClass = "bg-success"; break;
                                            case UnitQuotaStatus.Overdue: statusClass = "bg-danger"; break;
                                            case UnitQuotaStatus.PendingConfirmation: statusClass = "bg-info text-dark"; break;
                                        }
                                    }
                                    <span class="badge @statusClass">@quota.Status</span>
                                </td>
                                <td class="text-end">
                                    @if (quota.Status == UnitQuotaStatus.PendingConfirmation)
                                    {
                                        <div class="btn-group" role="group">
                                            <a href="@quota.ProofOfPaymentUrl" target="_blank" class="btn btn-sm btn-outline-primary">View Proof</a>

                                            <button type="button" class="btn btn-sm btn-outline-danger" data-bs-toggle="modal" data-bs-target="#rejectPaymentModal" data-quota-id="@quota.Id">
                                                Reject
                                            </button>

                                            <form asp-controller="CondoManagement" asp-action="ConfirmPayment" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="quotaId" value="@quota.Id" />
                                                <input type="hidden" name="condominiumId" value="@condo.Id" />
                                                <button type="submit" class="btn btn-sm btn-success">Confirm</button>
                                            </form>
                                        </div>
                                    }
                                    else if (quota.Status == UnitQuotaStatus.Paid && quota.ReceiptId.HasValue)
                                    {
                                        <a asp-action="Receipt" asp-route-id="@quota.ReceiptId" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-receipt-cutoff"></i> View Receipt
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center p-4">
                <p class="text-muted mb-0">No quotas found for this condominium.</p>
            </div>
        }
    </div>
</div>
<div class="mt-4">
    <a asp-action="Details" asp-route-id="@condo.Id" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
</div>

<!-- Rejection Modal -->
<div class="modal fade" id="rejectPaymentModal" tabindex="-1" aria-labelledby="rejectPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="CondoManagement" asp-action="RejectPayment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="quotaId" id="modalQuotaId" />
                <input type="hidden" name="condominiumId" value="@condo.Id" />
                <div class="modal-header">
                    <h5 class="modal-title" id="rejectPaymentModalLabel">Reject Payment Proof</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="rejectionReason" class="form-label">Reason for Rejection:</label>
                        <textarea name="RejectionReason" id="rejectionReason" class="form-control" rows="4" required minlength="10" placeholder="e.g., The uploaded receipt is for the wrong amount or is illegible."></textarea>
                        <div class="invalid-feedback">A reason of at least 10 characters is required.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Submit Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var rejectModal = document.getElementById('rejectPaymentModal');
            if (rejectModal) {
                rejectModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    var quotaId = button.getAttribute('data-quota-id');
                    var modalQuotaIdInput = rejectModal.querySelector('#modalQuotaId');
                    modalQuotaIdInput.value = quotaId;
                });
            }
        });
    </script>
}