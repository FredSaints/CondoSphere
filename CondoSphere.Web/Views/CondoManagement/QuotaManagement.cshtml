@model IEnumerable<CondoSphere.Core.DTOs.Financials.UnitQuotaDto>
@using CondoSphere.Core.DTOs.Condominiums
@using CondoSphere.Core.Enums

@{
    var condo = ViewData["Condominium"] as CondominiumDto;
    ViewData["Title"] = "Quota Management";

    // Pre-calculate KPI values from the model for the header cards
    var pendingConfirmationCount = Model.Count(q => q.Status == UnitQuotaStatus.PendingConfirmation);
    var overdueCount = Model.Count(q => q.Status == UnitQuotaStatus.Overdue);
    var paidThisMonthCount = Model.Count(q => q.Status == UnitQuotaStatus.Paid && q.PaymentDate.HasValue && q.PaymentDate.Value.Year == DateTime.Now.Year && q.PaymentDate.Value.Month == DateTime.Now.Month);
}

<style>
    /* New styles for sleek, compact KPI cards */
    .kpi-card-compact {
        display: flex;
        align-items: center;
        gap: 1rem;
        background-color: #ffffff;
        padding: 1rem;
        border-radius: 0.75rem;
        box-shadow: var(--shadow-sm);
        border: 1px solid var(--border-color);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .kpi-card-compact:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }

    .kpi-icon {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        color: #fff;
    }

        .kpi-icon.bg-primary {
            background-color: var(--primary-color);
        }

        .kpi-icon.bg-danger {
            background-color: var(--danger-color);
        }

        .kpi-icon.bg-success {
            background-color: var(--success-color);
        }

    .kpi-content .kpi-value {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1.1;
        margin-bottom: 0;
    }

    .kpi-content .kpi-label {
        font-size: 0.8rem;
        color: var(--text-secondary);
        margin-bottom: 0;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .table-quotas th {
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.8rem;
        letter-spacing: 0.05em;
    }

    .quota-unit-id {
        font-weight: 600;
        color: var(--text-primary);
    }

    .quota-description {
        font-size: 0.9rem;
        color: var(--text-secondary);
    }

    /* Style for rows that require manager action */
    .row-action-required {
        background-color: #f0f8ff !important; /* A light, noticeable blue */
        border-left: 4px solid var(--primary-color);
        border-right: 4px solid var(--primary-color);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <p class="text-muted mb-0">Review and confirm payments for: <strong>@condo.Name</strong></p>
    </div>
    <a asp-action="Details" asp-route-id="@condo.Id" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Dashboard
    </a>
</div>

<div class="card shadow-sm border-0">
    <div class="card-body p-4">

        <!-- KPI Summary Cards -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="kpi-card-compact">
                    <div class="kpi-icon bg-primary">
                        <i class="bi bi-patch-question-fill"></i>
                    </div>
                    <div class="kpi-content">
                        <p class="kpi-value text-primary">@pendingConfirmationCount</p>
                        <p class="kpi-label">Action Required</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="kpi-card-compact">
                    <div class="kpi-icon bg-danger">
                        <i class="bi bi-calendar-x-fill"></i>
                    </div>
                    <div class="kpi-content">
                        <p class="kpi-value text-danger">@overdueCount</p>
                        <p class="kpi-label">Overdue</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="kpi-card-compact">
                    <div class="kpi-icon bg-success">
                        <i class="bi bi-calendar-check-fill"></i>
                    </div>
                    <div class="kpi-content">
                        <p class="kpi-value text-success">@paidThisMonthCount</p>
                        <p class="kpi-label">Paid (This Month)</p>
                    </div>
                </div>
            </div>
        </div>

        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0 align-middle table-quotas">
                    <thead class="table-light">
                        <tr>
                            <th scope="col" style="width: 25%;">Unit / Description</th>
                            <th scope="col">Due Date</th>
                            <th scope="col" class="text-end">Amount</th>
                            <th scope="col" class="text-center">Status</th>
                            <th scope="col" class="text-center" style="width: 320px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var quota in Model.OrderBy(q => q.Status == UnitQuotaStatus.PendingConfirmation ? 0 : 1))
                        {
                            <tr class="@(quota.Status == UnitQuotaStatus.PendingConfirmation ? "row-action-required" : "")">
                                <td>
                                    <div class="quota-unit-id">@quota.UnitIdentifier</div>
                                    <div class="quota-description">@quota.Description</div>
                                </td>
                                <td>@quota.DueDate.ToString("yyyy-MM-dd")</td>
                                <td class="text-end fw-bold">@quota.AmountDue.ToString("C")</td>
                                <td class="text-center">
                                    @{
                                        var statusClass = "bg-secondary";
                                        switch (quota.Status)
                                        {
                                            case UnitQuotaStatus.Pending: statusClass = "bg-warning text-dark"; break;
                                            case UnitQuotaStatus.Paid: statusClass = "bg-success"; break;
                                            case UnitQuotaStatus.Overdue: statusClass = "bg-danger"; break;
                                            case UnitQuotaStatus.PendingConfirmation: statusClass = "bg-info text-dark"; break;
                                        }
                                    }
                                    <span class="badge rounded-pill @statusClass">@quota.Status.ToString().Replace("Confirmation", "")</span>
                                </td>
                                <td class="text-center">
                                    @if (quota.Status == UnitQuotaStatus.PendingConfirmation)
                                    {
                                        <div class="btn-group" role="group">
                                            <a href="@quota.ProofOfPaymentUrl" target="_blank" class="btn btn-sm btn-outline-secondary">
                                                <i class="bi bi-eye-fill me-1"></i>View Proof
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger" data-bs-toggle="modal" data-bs-target="#rejectPaymentModal" data-quota-id="@quota.Id">
                                                <i class="bi bi-x-circle-fill me-1"></i>Reject
                                            </button>
                                            <form asp-controller="CondoManagement" asp-action="ConfirmPayment" method="post" class="d-inline">
                                                @Html.AntiForgeryToken()
                                                <input type="hidden" name="quotaId" value="@quota.Id" />
                                                <input type="hidden" name="condominiumId" value="@condo.Id" />
                                                <button type="submit" class="btn btn-sm btn-success">
                                                    <i class="bi bi-check-circle-fill me-1"></i>Confirm
                                                </button>
                                            </form>
                                        </div>
                                    }
                                    else if (quota.Status == UnitQuotaStatus.Paid && quota.ReceiptId.HasValue)
                                    {
                                        <a asp-action="Receipt" asp-route-id="@quota.ReceiptId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-receipt-cutoff me-1"></i> View Receipt
                                        </a>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center p-5">
                <i class="bi bi-journal-check fs-1 text-muted"></i>
                <h4 class="mt-3">All Quotas Are Settled</h4>
                <p class="text-muted">There are no outstanding or pending quotas for this condominium. Great job!</p>
            </div>
        }
    </div>
</div>

<!-- Rejection Modal -->
<div class="modal fade" id="rejectPaymentModal" tabindex="-1" aria-labelledby="rejectPaymentModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="CondoManagement" asp-action="RejectPayment" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="quotaId" id="modalQuotaId" />
                <input type="hidden" name="condominiumId" value="@condo.Id" />
                <div class="modal-header bg-danger text-white">
                    <h5 class="modal-title" id="rejectPaymentModalLabel"><i class="bi bi-x-circle-fill me-2"></i>Reject Payment Proof</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="form-group">
                        <label for="rejectionReason" class="form-label">Reason for Rejection:</label>
                        <textarea name="RejectionReason" id="rejectionReason" class="form-control" rows="4" required minlength="10" placeholder="e.g., The uploaded receipt is for the wrong amount or is illegible. This reason will be sent to the resident."></textarea>
                        <div class="invalid-feedback">A reason of at least 10 characters is required.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Submit Rejection</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var rejectModal = document.getElementById('rejectPaymentModal');
            if (rejectModal) {
                rejectModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    var quotaId = button.getAttribute('data-quota-id');
                    var modalQuotaIdInput = rejectModal.querySelector('#modalQuotaId');
                    modalQuotaIdInput.value = quotaId;
                });
            }
        });
    </script>
}