@model CondoSphere.Web.Models.RegisterResidentViewModel

@{
    ViewData["Title"] = "Register New Resident";
    var unitIdentifier = ViewData["UnitIdentifier"] as string;
    ViewData["IsFullWidth"] = true;
}

<style>
    body {
        background-color: var(--light-bg);
    }
</style>

<div class="container my-5">
    <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-md-11 col-lg-9 col-xl-8">

            <div class="card shadow-lg border-0">
                <div class="card-header text-center py-4" style="background: var(--primary-gradient);">
                    <h2 class="mb-1 text-white"><i class="bi bi-person-plus-fill me-2"></i>@ViewData["Title"]</h2>
                    <p class="mb-0 small text-white-50">And assign to Unit: <strong>@unitIdentifier</strong></p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <div class="alert alert-info d-flex align-items-center mb-4">
                        <i class="bi bi-people-fill flex-shrink-0 me-3" style="font-size: 1.5rem;"></i>
                        <div>
                            Looking for an existing resident? <a asp-action="AssignResident" asp-route-unitId="@Model.UnitId" asp-route-condominiumId="@Model.CondominiumId" class="alert-link fw-bold">Assign an existing resident instead</a>.
                        </div>
                    </div>

                    <form asp-action="RegisterResident" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-danger mb-3"></div>
                        <input type="hidden" asp-for="UnitId" />
                        <input type="hidden" asp-for="CondominiumId" />

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="FirstName" class="form-control" placeholder="First Name" />
                                    <label asp-for="FirstName"></label>
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="LastName" class="form-control" placeholder="Last Name" />
                                    <label asp-for="LastName"></label>
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control" placeholder="Email Address" />
                                    <label asp-for="Email"></label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="Phone Number" />
                                    <label asp-for="PhoneNumber"></label>
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Register and Assign Resident</button>
                            <a asp-action="Details" asp-route-id="@Model.CondominiumId" class="btn btn-secondary btn-lg">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}