@model IEnumerable<CondoSphere.Core.DTOs.Notifications.NotificationDto>

@{
    ViewData["Title"] = "All Notifications";
}

<h1>@ViewData["Title"]</h1>
<p class="text-muted">Your complete notification history.</p>
<hr />

<div class="list-group">
    @if (Model.Any())
    {
        @foreach (var notification in Model)
        {
            <a href="@notification.LinkUrl" class="list-group-item list-group-item-action flex-column align-items-start @(notification.IsRead ? "" : "list-group-item-light")">
                <div class="d-flex w-100 justify-content-between">
                    <h5 class="mb-1 @(notification.IsRead ? "" : "fw-bold")">@notification.Title</h5>
                    <small>@notification.SentDate.ToLocalTime().ToString("g")</small>
                </div>
                <p class="mb-1">@notification.Message</p>
            </a>
        }
    }
    else
    {
        <div class="text-center p-5">
            <p class="text-muted">You have no notifications in your history.</p>
        </div>
    }
</div>

<div class="mt-4">
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to Portal
    </a>
</div>