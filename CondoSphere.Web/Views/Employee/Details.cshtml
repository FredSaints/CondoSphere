@model CondoSphere.Web.Models.EmployeeInterventionViewModel
@using CondoSphere.Core.Enums

@{
    ViewData["Title"] = "Task Details";
    bool isTerminalState = Model.Intervention.Status == InterventionStatus.Completed || Model.Intervention.Status == InterventionStatus.Cancelled;
}

<h1>@Model.Occurrence.Title</h1>
<p class="text-muted">Task scheduled for @Model.Intervention.StartDate.ToLocalTime().ToString("f")</p>
<hr />

<div class="row">
    <div class="col-md-8">
        @* ===== CARD 1: THE TASK (INTERVENTION) & STATUS UPDATE FORM ===== *@
        <div class="card shadow-sm mb-4">
            <div class="card-header">
                <h5 class="mb-0">Your Assigned Task</h5>
            </div>
            <div class="card-body">
                <dl class="row align-items-center">
                    <dt class="col-sm-3">Task Description</dt>
                    <dd class="col-sm-9">@Model.Intervention.Description</dd>

                    <dt class="col-sm-3">Status</dt>
                    <dd class="col-sm-9">
                        @* ===== START: CONDITIONAL UI LOGIC ===== *@
                        @if (isTerminalState)
                        {
                            // If task is completed or cancelled, show a static badge
                            var statusClass = Model.Intervention.Status == InterventionStatus.Completed ? "bg-success" : "bg-danger";
                            <span class="badge @statusClass fs-6">@Model.Intervention.Status</span>
                        }
                        else
                        {
                            // Otherwise, show the interactive update form
                            <form id="updateStatusForm" asp-action="UpdateStatus" asp-route-interventionId="@Model.Intervention.Id" method="post">
                                @Html.AntiForgeryToken()
                                <div class="input-group" style="max-width: 300px;">
                                    <select asp-for="StatusUpdate.Status" asp-items="Html.GetEnumSelectList<InterventionStatus>()" class="form-select"></select>
                                    <button type="submit" class="btn btn-primary">Update Status</button>
                                </div>
                                <span asp-validation-for="StatusUpdate.Status" class="text-danger"></span>
                            </form>
                        }
                        @* ===== END: CONDITIONAL UI LOGIC ===== *@
                    </dd>
                </dl>
            </div>
        </div>

        @* ... The rest of the page (Original Report, Image, Back button) remains the same ... *@
    </div>
</div>

@* ===== ADD THIS CONFIRMATION MODAL ===== *@
<div class="modal fade" id="statusConfirmModal" tabindex="-1" aria-labelledby="statusConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="statusConfirmModalLabel">Confirm Status Change</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                Are you sure you want to mark this task as <strong id="newStatusText"></strong>? This action cannot be undone.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-success" id="confirmStatusChangeBtn">Yes, Confirm</button>
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    @* ===== ADD THIS SCRIPT FOR CONFIRMATION LOGIC ===== *@
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const statusForm = document.getElementById('updateStatusForm');
            if (statusForm) {
                const statusSelect = statusForm.querySelector('select');
                const confirmModal = new bootstrap.Modal(document.getElementById('statusConfirmModal'));
                const newStatusText = document.getElementById('newStatusText');
                const confirmBtn = document.getElementById('confirmStatusChangeBtn');

                let originalStatus = statusSelect.value;

                statusForm.addEventListener('submit', function (event) {
                    const selectedValue = statusSelect.options[statusSelect.selectedIndex];
                    const newStatus = selectedValue.text;

                    // Check if the new status is 'Completed' or 'Cancelled'
                    if (newStatus === '@InterventionStatus.Completed.ToString()' || newStatus === '@InterventionStatus.Cancelled.ToString()') {
                        // Prevent the form from submitting immediately
                        event.preventDefault();

                        // Show the confirmation modal
                        newStatusText.textContent = newStatus.toLowerCase();
                        confirmModal.show();
                    }
                });

                confirmBtn.addEventListener('click', function () {
                    // When the user confirms, submit the form
                    statusForm.submit();
                });

                // If the user closes the modal without confirming, reset the dropdown
                document.getElementById('statusConfirmModal').addEventListener('hidden.bs.modal', function () {
                    statusSelect.value = originalStatus;
                });
            }
        });
    </script>
}