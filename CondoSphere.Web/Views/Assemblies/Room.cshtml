@model IEnumerable<CondoSphere.Core.DTOs.Assemblies.AssemblyMessageDto>
@{
    ViewData["Title"] = "Sala";
    var condominiumId = (int)ViewData["CondominiumId"];
    var assemblyId = (int)ViewData["AssemblyId"];
}
<h2>Chat da Assembleia</h2>

<div class="card mb-3">
    <div class="card-body" style="max-height: 400px; overflow:auto;">
        @foreach (var m in Model.OrderBy(x => x.CreatedAt))
        {
            <div class="mb-2">
                <div class="small text-muted">@m.CreatedAt.ToLocalTime():g — @m.SenderName</div>
                <div>@m.Message</div>
            </div>
            <hr />
        }
    </div>
</div>

<form asp-action="PostMessage" method="post"
      asp-route-condominiumId="@condominiumId" asp-route-assemblyId="@assemblyId">
    <div class="input-group">
        <input name="Message" class="form-control" placeholder="Escreve uma mensagem..." />
        <button class="btn btn-primary" type="submit">Enviar</button>
    </div>
</form>

<div class="mt-3">
    <a class="btn btn-secondary" asp-action="Index" asp-route-condominiumId="@condominiumId">Voltar à lista</a>
    <a class="btn btn-outline-secondary" asp-action="Room" asp-route-condominiumId="@condominiumId" asp-route-assemblyId="@assemblyId">Atualizar</a>
</div>
