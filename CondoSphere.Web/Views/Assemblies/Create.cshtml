@model CondoSphere.Core.DTOs.Assemblies.CreateAssemblyDto
@{
    ViewData["Title"] = "Criar Assembleia";
}
<h2>@ViewData["Title"]</h2>

<form asp-action="Create" method="post">
    <input type="hidden" asp-for="CondominiumId" />
    <div class="mb-3">
        <label asp-for="Title" class="form-label"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="ScheduledAt" class="form-label">Data/Hora</label>
        <input asp-for="ScheduledAt" type="datetime-local" class="form-control" />
        <span asp-validation-for="ScheduledAt" class="text-danger"></span>
    </div>
    <div class="mb-3">
        <label asp-for="Agenda" class="form-label"></label>
        <textarea asp-for="Agenda" class="form-control" rows="4"></textarea>
        <span asp-validation-for="Agenda" class="text-danger"></span>
    </div>
    <button class="btn btn-primary" type="submit">Criar</button>
    <a class="btn btn-secondary" asp-action="Index" asp-route-condominiumId="@Model.CondominiumId">Voltar</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
