@model IEnumerable<CondoSphere.Core.DTOs.Assemblies.AssemblyDto>
@{
    ViewData["Title"] = "Assemblies";
    var condominiumId = (int)ViewData["CondominiumId"];
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>Assemblies</h2>
    <a class="btn btn-primary" asp-action="Create" asp-route-condominiumId="@condominiumId">Criar nova</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
     <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
     <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}

<table class="table table-striped">
    <thead>
        <tr>
            <th>Data</th>
            <th>Título</th>
            <th>Atas</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var a in Model)
        {
            <tr>
                <td>@a.ScheduledAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                <td>@a.Title</td>
                <td>
                    @if (!string.IsNullOrWhiteSpace(a.MinutesUrl))
                    {
                        <a href="@a.MinutesUrl" target="_blank">Abrir</a>
                    }
                </td>
                <td class="text-end">
                    <a class="btn btn-sm btn-outline-secondary" asp-action="Invite"
                       asp-route-condominiumId="@condominiumId" asp-route-assemblyId="@a.Id">Convidar</a>
                    <a class="btn btn-sm btn-outline-primary" asp-action="Room"
                       asp-route-condominiumId="@condominiumId" asp-route-assemblyId="@a.Id">Sala</a>
                </td>
            </tr>
        }
    </tbody>
</table>
