@model CondoSphere.Core.DTOs.Assemblies.SendAssemblyInvitesDto
@{
    ViewData["Title"] = "Invite Participants";
    var condominiumId = (int)(ViewData["CondominiumId"] ?? 0);
    var assemblyId = (int)(ViewData["AssemblyId"] ?? 0);
    var residents = ViewBag.Residents as List<SelectListItem> ?? new();
}

<div class="container my-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-header"><h3 class="mb-0"><i class="bi bi-envelope me-2"></i>Invite Participants</h3></div>
        <div class="card-body">
          <form asp-action="Invite" asp-route-condominiumId="@condominiumId" asp-route-assemblyId="@assemblyId" method="post">
                        @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-check form-switch mb-3">
              <input class="form-check-input" asp-for="InviteAllResidents" />
              <label class="form-check-label" asp-for="InviteAllResidents">Invite all residents</label>
            </div>

            <div class="mb-3">
              <label class="form-label">Select residents</label>
              <select asp-for="SelectedResidentIds"
                      asp-items="residents"
                      multiple
                      class="form-select"
                      size="8">
              </select>
              <span class="form-text">Mantém Ctrl/Cmd para seleção múltipla.</span>
            </div>

            <div class="form-check form-switch mb-4">
              <input class="form-check-input" asp-for="IncludeEmployees" />
              <label class="form-check-label" asp-for="IncludeEmployees">Include employees</label>
            </div>

            <div class="form-floating mb-3">
              <input asp-for="EmailSubject" class="form-control" placeholder="Subject" />
              <label asp-for="EmailSubject">Email Subject</label>
            </div>

            <div class="form-floating mb-3">
              <textarea asp-for="EmailBody" class="form-control" style="height:140px" placeholder="Custom email body (optional)"></textarea>
              <label asp-for="EmailBody">Email Body (optional)</label>
            </div>

            <div class="form-floating mb-4">
              <textarea asp-for="SmsBody" class="form-control" style="height:100px" placeholder="Custom SMS body (optional)"></textarea>
              <label asp-for="SmsBody">SMS Body (optional)</label>
            </div>

            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">
                <i class="bi bi-send-check me-1"></i>Send Invites
              </button>
              <a asp-action="Unified" asp-route-condominiumId="@condominiumId" class="btn btn-secondary">Back</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
@section Scripts {
     <partial name="_ValidationScriptsPartial" />
}
