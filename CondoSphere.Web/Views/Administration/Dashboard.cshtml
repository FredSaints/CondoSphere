@model CondoSphere.Web.Models.AdminBiDashboardViewModel

@{
    ViewData["Title"] = "Company Dashboard";
    var stats = Model?.MainStats;
}

<div class="d-flex justify-content-between align-items-center mb-4 print-hide">
    <h1>@ViewData["Title"]</h1>
    <a asp-action="Index" class="btn btn-secondary">Back to Management View</a>
</div>

<!-- KPI Cards -->
@if (stats != null)
{
    <div class="row g-4 mb-4">
        <div class="col-xl-2 col-md-4 col-6"><div class="card h-100 p-3 text-center shadow-sm"><div class="fs-4 fw-bold">@stats.TotalCondominiums</div><small class="text-muted">Condominiums</small></div></div>
        <div class="col-xl-2 col-md-4 col-6"><div class="card h-100 p-3 text-center shadow-sm"><div class="fs-4 fw-bold">@stats.TotalUnits</div><small class="text-muted">Total Units</small></div></div>
        <div class="col-xl-2 col-md-4 col-6"><div class="card h-100 p-3 text-center shadow-sm"><div class="fs-4 fw-bold">@stats.TotalResidents</div><small class="text-muted">Active Residents</small></div></div>
        <div class="col-xl-2 col-md-4 col-6"><div class="card h-100 p-3 text-center shadow-sm"><div class="fs-4 fw-bold text-success">@stats.TotalIncomeThisMonth.ToString("C")</div><small class="text-muted">Income (This Month)</small></div></div>
        <div class="col-xl-2 col-md-4 col-6"><div class="card h-100 p-3 text-center shadow-sm"><div class="fs-4 fw-bold text-danger">@stats.TotalExpensesThisMonth.ToString("C")</div><small class="text-muted">Expenses (This Month)</small></div></div>
        <div class="col-xl-2 col-md-4 col-6"><div class="card h-100 p-3 text-center shadow-sm"><div class="fs-4 fw-bold text-warning">@stats.OpenOccurrences</div><small class="text-muted">Open Issues</small></div></div>
    </div>
}
else
{
    <div class="alert alert-warning">Dashboard statistics are currently unavailable.</div>
}

<hr />

<!-- Charts & Hotspots Section -->
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Income vs. Expenses (Last 6 Months)</h5>
                <div class="flex-grow-1" style="position: relative; height: 300px;">
                    <canvas id="financialTrendChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card shadow-sm h-100">
            <div class="card-body d-flex flex-column">
                <h5 class="card-title">Occurrences by Status</h5>
                <div class="flex-grow-1" style="position: relative; height: 300px;">
                    <canvas id="occurrenceStatusChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12">
        <div class="card shadow-sm">
            <div class="card-body">
                <h5 class="card-title">Condominium Hotspots (Top 5 by Open Issues)</h5>
                @if (Model?.CondoHotspots != null && Model.CondoHotspots.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover mt-3">
                            <thead class="table-light">
                                <tr>
                                    <th>Condominium Name</th>
                                    <th class="text-center">Open Issues</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var hotspot in Model.CondoHotspots)
                                {
                                    <tr>
                                        <td>@hotspot.CondominiumName</td>
                                        <td class="text-center">@hotspot.OpenIssuesCount</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted mt-3">No open issues found across all condominiums. Great job!</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/chart.js/dist/chart.umd.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // --- Financial Trend Chart: Bar Chart ---
            @if (Model?.FinancialTrend != null && Model.FinancialTrend.Any())
            {
                    <text>
                    const financialCtx = document.getElementById('financialTrendChart');
                    if (financialCtx) {
                        const financialLabels = @Html.Raw(Json.Serialize(Model.FinancialTrend.Select(f => f.Month)));
                        const incomeData = @Html.Raw(Json.Serialize(Model.FinancialTrend.Select(f => f.TotalIncome)));
                        const expenseData = @Html.Raw(Json.Serialize(Model.FinancialTrend.Select(f => f.TotalExpenses)));

                        new Chart(financialCtx, {
                            type: 'bar',
                            data: {
                                labels: financialLabels,
                                datasets: [
                                    {
                                        label: 'Income',
                                        data: incomeData,
                                        backgroundColor: 'rgba(25, 135, 84, 0.7)' // Bootstrap Success
                                    },
                                    {
                                        label: 'Expenses',
                                        data: expenseData,
                                        backgroundColor: 'rgba(220, 53, 69, 0.7)' // Bootstrap Danger
                                    }
                                ]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                scales: {
                                    y: {
                                        beginAtZero: true
                                    }
                                }
                            }
                        });
                    }
                    </text>
            }

            // --- Occurrence Status Chart: Doughnut Chart ---
            @if (Model?.OccurrenceSummary != null && Model.OccurrenceSummary.Any())
            {
                     <text>
                    const occurrenceCtx = document.getElementById('occurrenceStatusChart');
                    if (occurrenceCtx) {
                        const occurrenceLabels = @Html.Raw(Json.Serialize(Model.OccurrenceSummary.Select(o => o.StatusName)));
                        const occurrenceData = @Html.Raw(Json.Serialize(Model.OccurrenceSummary.Select(o => o.Count)));

                        new Chart(occurrenceCtx, {
                            type: 'doughnut',
                            data: {
                                labels: occurrenceLabels,
                                datasets: [{
                                    label: 'Occurrences',
                                    data: occurrenceData,
                                    backgroundColor: [
                                        'rgba(220, 53, 69, 0.7)',  // Danger
                                        'rgba(255, 193, 7, 0.7)',   // Warning
                                        'rgba(13, 202, 240, 0.7)',   // Info
                                        'rgba(25, 135, 84, 0.7)',  // Success
                                        'rgba(108, 117, 125, 0.7)'   // Secondary
                                    ],
                                    hoverOffset: 4
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false
                            }
                        });
                    }
                    </text>
            }
        });
    </script>
}