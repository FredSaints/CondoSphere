@model CondoSphere.Core.DTOs.Messages.SendMessageDto
@{
    ViewData["Title"] = "Compose Message";
    var contacts = ViewBag.Contacts as IEnumerable<CondoSphere.Core.DTOs.Account.SimpleUserDto>;
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5><i class="bi bi-envelope me-2"></i>Compose New Message</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Compose" method="post">
                        <div class="mb-3">
                            <label asp-for="ReceiverId" class="form-label">To:</label>
                            <select asp-for="ReceiverId" class="form-select">
                                <option value="0">Select recipient...</option>
                                @if (contacts != null)
                                {
                                    @foreach (var contact in contacts)
                                    {
                                        <option value="@contact.Id">@contact.FullName</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ReceiverId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Subject" class="form-label">Subject:</label>
                            <input asp-for="Subject" class="form-control" placeholder="Enter message subject">
                            <span asp-validation-for="Subject" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Content" class="form-label">Message:</label>
                            <textarea asp-for="Content" class="form-control" rows="8" placeholder="Type your message here..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-1"></i> Back to Inbox
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send me-1"></i> Send Message
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>