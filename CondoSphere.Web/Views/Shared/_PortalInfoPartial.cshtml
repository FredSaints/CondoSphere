@model CondoSphere.Web.Models.PortalDashboardViewModel

<div class="row">
    <div class="col-md-6">
        <h5 class="mb-3">My Units</h5>
        <ul class="list-group">
            @if (Model.MyUnits.Any())
            {
                @foreach (var unit in Model.MyUnits)
                {
                    <li class="list-group-item">@unit.Identifier</li>
                }
            }
            else
            {
                <li class="list-group-item text-muted">You are not assigned to any units.</li>
            }
        </ul>
    </div>

    <div class="col-md-6">
        <h5 class="mb-3">Condominium Documents</h5>
        @if (Model.MyDocuments.Any())
        {
            <div class="list-group">
                @foreach (var condoGroup in Model.MyDocuments.GroupBy(d => d.CondominiumName))
                {
                    <div class="list-group-item list-group-item-light fw-bold">
                        <i class="bi bi-building me-2"></i>@condoGroup.Key
                    </div>
                    @foreach (var doc in condoGroup)
                    {
                        <div class="list-group-item d-flex justify-content-between align-items-center">
                            <div class="flex-grow-1">
                                <h6 class="mb-1">@doc.Title</h6>
                                <p class="mb-1 text-muted small">@doc.Category - Uploaded on @doc.UploadDate.ToLocalTime().ToString("d")</p>
                            </div>
                            <div class="btn-group flex-shrink-0 ms-3">
                                <a asp-controller="Portal"
                                   asp-action="ViewDocument"
                                   asp-route-documentId="@doc.Id"
                                   class="btn btn-sm btn-outline-secondary"
                                   title="View in new tab"
                                   target="_blank">
                                    <i class="bi bi-eye-fill"></i> View
                                </a>
                                <a asp-controller="Portal"
                                   asp-action="DownloadDocument"
                                   asp-route-documentId="@doc.Id"
                                   class="btn btn-sm btn-outline-primary"
                                   title="Download file">
                                    <i class="bi bi-download"></i> Download
                                </a>
                            </div>
                        </div>
                    }
                }
            </div>
        }
        else
        {
            <div class="text-center text-muted p-4 border rounded">
                <i class="bi bi-file-earmark-excel fs-1"></i>
                <p class="mt-2 mb-0">No documents are available for your condominium at this time.</p>
            </div>
        }
    </div>
</div>