@using CondoSphere.Core
@using Microsoft.AspNetCore.Identity

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CondoSphere</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/modern-theme.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CondoSphere.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <style>
        /* --- NAVBAR RESIZING --- */
        :root {
            --navbar-scale-factor: 1.4;
        }

        .modern-navbar .nav-link {
            font-size: calc(1rem * var(--navbar-scale-factor));
            padding: calc(0.7rem * var(--navbar-scale-factor)) calc(1rem * var(--navbar-scale-factor));
        }

        .modern-navbar .navbar-brand {
            font-size: calc(1.5rem * var(--navbar-scale-factor));
        }

        .modern-navbar .nav-link i {
            font-size: calc(1.1rem * var(--navbar-scale-factor));
        }

        .modern-navbar .dropdown-toggle img {
            width: calc(30px * var(--navbar-scale-factor));
            height: calc(30px * var(--navbar-scale-factor));
        }

        .modern-navbar .role-badge {
            font-size: calc(0.75rem * var(--navbar-scale-factor));
            padding: calc(0.25rem * var(--navbar-scale-factor)) calc(0.75rem * var(--navbar-scale-factor));
        }

        .modern-navbar .nav-btn {
            font-size: calc(1rem * var(--navbar-scale-factor));
            padding: calc(0.7rem * var(--navbar-scale-factor)) calc(1rem * var(--navbar-scale-factor));
            line-height: 1;
        }

        #notificationDropdown {
            position: relative;
            vertical-align: middle !important;
        }

            #notificationDropdown .bi-bell-fill {
                font-size: calc(1.25rem * var(--navbar-scale-factor));
                line-height: 1;
                display: inline-block;
                vertical-align: middle;
            }

        #notification-badge {
            font-size: calc(0.65rem * var(--navbar-scale-factor));
            min-width: calc(18px * var(--navbar-scale-factor));
            height: calc(18px * var(--navbar-scale-factor));
            top: 2px;
            right: -2px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0;
        }

        #notification-dropdown-container {
            position: relative;
            z-index: 2000;
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm modern-navbar">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-buildings me-2" style="font-size: 1.5rem;"></i>
                    CondoSphere
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                    <i class="bi bi-list" style="font-size: 1.5rem;"></i>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">

                    <ul class="navbar-nav flex-grow-1 gap-2">
                        <li class="nav-item">
                            <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-house me-1"></i> Home
                            </a>
                        </li>

                        @if (User.Identity != null && User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link messages-nav" asp-controller="Messages" asp-action="Index">
                                    <i class="bi bi-envelope me-1"></i> Messages
                                    <span class="message-badge" id="message-badge" style="display: none;">0</span>
                                </a>
                            </li>

                            if (User.IsInRole(RoleConstants.CompanyAdmin))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Administration" asp-action="Index">
                                        <i class="bi bi-shield-check me-1"></i> Admin Panel
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Administration" asp-action="Dashboard">
                                        <i class="bi bi-graph-up me-1"></i> Analytics
                                    </a>
                                </li>
                            }

                            if (User.IsInRole(RoleConstants.CondoManager))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="CondoManagement" asp-action="Index">
                                        <i class="bi bi-building me-1"></i> My Buildings
                                    </a>
                                </li>
                            }
                            if (User.IsInRole(RoleConstants.CondoResident))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Portal" asp-action="Index">
                                        <i class="bi bi-person-workspace me-1"></i> My Portal
                                    </a>
                                </li>
                            }
  
                            if(User.IsInRole(RoleConstants.Employee))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Employee" asp-action="Index">
                                        <i class="bi bi-list-task me-1"></i> My Tasks
                                    </a>
                                </li>
                            }
                            <li class="nav-item">
                                <a class="btn btn-primary nav-btn"
                                   href="https://drive.google.com/uc?export=download&id=FILE_ID">
                                    <i class="bi bi-download me-1"></i> Download our mobile app
                                </a>
                            </li>
                        }
                    </ul>

                    <div class="d-flex align-items-center gap-3">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole(RoleConstants.CompanyAdmin))
                            {
                                <span class="role-badge role-admin">Admin</span>
                            }
                            else if (User.IsInRole(RoleConstants.CondoManager))
                            {
                                <span class="role-badge role-manager">Manager</span>
                            }
                            else if (User.IsInRole(RoleConstants.Employee))
                            {
                                <span class="role-badge role-employee">Employee</span>
                            }
                            else if (User.IsInRole(RoleConstants.CondoResident))
                            {
                                <span class="role-badge role-resident">Resident</span>
                            }
                        }

                        <partial name="_LoginPartial" />
                    </div>
                </div>
            </div>
        </nav>
    </header>

    @{
        var isFullWidth = ViewData["IsFullWidth"] as bool? ?? false;
        var containerClass = isFullWidth ? "container-fluid" : "container";
    }

    <div class="@containerClass">
        <main role="main" class="pb-3">
            @if (TempData["SuccessMessage"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>
                    @TempData["SuccessMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (isFullWidth)
            {
                @RenderBody()
            }
            else
            {
                <div class="main-container">
                    @RenderBody()
                </div>
            }
        </main>
    </div>


    <footer class="footer text-muted">
        <div class="container text-center">
            <div class="d-flex justify-content-center align-items-center gap-4">
                <span>© 2025 CondoSphere</span>
                <span>|</span>
                <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-decoration-none">Privacy Policy</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const currentPath = window.location.pathname;
            const navLinks = document.querySelectorAll('.nav-link');

            navLinks.forEach(link => {
                if (link.getAttribute('href') === currentPath) {
                    link.classList.add('active');
                }
            });

            const urlParams = new URLSearchParams(window.location.search);
            const activeTabId = urlParams.get('activeTab');
            if (activeTabId) {
                const tabToActivate = document.getElementById(activeTabId);
                if (tabToActivate) {
                    new bootstrap.Tab(tabToActivate).show();
                }
            }

            if (typeof jwtToken !== 'undefined' && jwtToken) {
                loadUnreadMessageCount();
                setInterval(loadUnreadMessageCount, 30000);
            }
        });

        async function loadUnreadMessageCount() {
            try {
                const response = await fetch('/api/messages/unread-count', {
                    headers: { 'Authorization': `Bearer ${jwtToken}` }
                });
                if (response.ok) {
                    const data = await response.json();
                    const badge = document.getElementById('message-badge');
                    if (data.unreadCount > 0) {
                        badge.textContent = data.unreadCount;
                        badge.style.display = 'flex';
                    } else {
                        badge.style.display = 'none';
                    }
                }
            } catch (error) {
                console.error('Error loading unread message count:', error);
            }
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>