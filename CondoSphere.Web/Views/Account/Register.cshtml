@model CondoSphere.Core.DTOs.Account.RegisterDto

@{
    ViewData["Title"] = "Register Your Company";
    // This flag tells _Layout.cshtml not to render the white ".main-container" box
    ViewData["IsFullWidth"] = true;
}

<style>
    /* Use a light grey background for this page */
    body {
        background: var(--light-bg);
    }
</style>

<div class="container my-5">
    <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-md-11 col-lg-9 col-xl-8">

            <div class="card shadow-lg border-0">
                <div class="card-header text-center py-4" style="background: var(--primary-gradient);">
                    <h2 class="mb-1 text-white"><i class="bi bi-building-fill-add me-2"></i>@ViewData["Title"]</h2>
                    <p class="mb-0 small text-white-50">Sign up to start managing your properties with CondoSphere</p>
                </div>

                <div class="card-body p-4 p-md-5">
                    <form asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>

                        <!-- Company Information Section -->
                        <h4 class="mb-3"><i class="bi bi-briefcase-fill me-2 text-primary"></i>Company Information</h4>
                        <div class="row">
                            <div class="col-md-12 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CompanyName" class="form-control" placeholder="Your Company LLC" />
                                    <label asp-for="CompanyName"></label>
                                    <span asp-validation-for="CompanyName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CompanyEmail" class="form-control" placeholder="contact@company.com" />
                                    <label asp-for="CompanyEmail"></label>
                                    <span asp-validation-for="CompanyEmail" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="CompanyPhoneNumber" class="form-control" placeholder="+123456789" />
                                    <label asp-for="CompanyPhoneNumber"></label>
                                    <span asp-validation-for="CompanyPhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Address" class="form-control" placeholder="123 Main Street, Anytown" />
                                    <label asp-for="Address"></label>
                                    <span asp-validation-for="Address" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="VatNumber" class="form-control" placeholder="VAT Number" />
                                    <label asp-for="VatNumber"></label>
                                    <span asp-validation-for="VatNumber" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <!-- Administrator Account Section -->
                        <h4 class="mb-3"><i class="bi bi-person-fill-gear me-2 text-primary"></i>Your Administrator Account</h4>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="FirstName" class="form-control" placeholder="John" />
                                    <label asp-for="FirstName"></label>
                                    <span asp-validation-for="FirstName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="LastName" class="form-control" placeholder="Doe" />
                                    <label asp-for="LastName"></label>
                                    <span asp-validation-for="LastName" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Email" class="form-control" placeholder="you@example.com" />
                                    <label asp-for="Email"></label>
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="PhoneNumber" class="form-control" placeholder="Your Phone Number" />
                                    <label asp-for="PhoneNumber"></label>
                                    <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="Password" type="password" class="form-control" placeholder="Password" />
                                    <label asp-for="Password"></label>
                                    <span asp-validation-for="Password" class="text-danger small"></span>
                                </div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <div class="form-floating">
                                    <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm Password" />
                                    <label asp-for="ConfirmPassword"></label>
                                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-4">
                            <button type="submit" class="btn btn-primary btn-lg">Create Account</button>
                        </div>
                    </form>
                </div>

                <div class="card-footer text-center py-3 bg-light">
                    <p class="mb-0">Already have an account? <a asp-controller="Account" asp-action="Login">Sign in</a></p>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}