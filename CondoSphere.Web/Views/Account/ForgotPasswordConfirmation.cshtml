@{
    ViewData["Title"] = "Check Your Email";
    ViewData["IsFullWidth"] = true;
}

<style>
    body {
        background: var(--light-bg);
    }
</style>

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-md-11 col-lg-9 col-xl-8">

            <div class="card shadow-lg border-0 text-center">
                <div class="card-header py-4" style="background: var(--primary-gradient);">
                    <i class="bi bi-envelope-check-fill text-white" style="font-size: 3rem;"></i>
                    <h2 class="mb-0 mt-2 text-white">@ViewData["Title"]</h2>
                </div>

                <div class="card-body p-4 p-md-5">
                    <h5 class="card-title mb-3">Password Reset Email Sent</h5>
                    <p class="text-muted">
                        @ViewData["Message"]
                    </p>
                    <hr class="my-4" />
                    <p class="small text-muted mb-0">
                        If you don't see the email, please check your spam or junk folder before trying again.
                    </p>
                </div>

                <div class="card-footer py-3 bg-light">
                    <a asp-action="Login" class="btn btn-primary">
                        <i class="bi bi-arrow-left me-1"></i>
                        Return to Login
                    </a>
                </div>
            </div>

        </div>
    </div>
</div>